# =============================================================================
# Machine config for scaling_validated.sh
# Copy this file, fill in values for your machine, then:
#   source my_machine.env && bash scripts/scaling_validated.sh
# =============================================================================

# Path to the Sirius repo (contains build/release/duckdb after building)
export SIRIUS_DIR="$HOME/sirius"

# Pixi environment name — matches the CUDA version for your GPU
#   sm_75 (RTX series, Quadro RTX): cuda12
#   sm_80/sm_86 (A100, A5000):      default  (cuda13)
export PIXI_ENV="default"

# Source DuckDB with address_flows_daily_dict + entity_address_map_int
# Generate with: python3 scripts/generate_2yr_data.py
export SRC_DB="/tmp/crypto_2yr.duckdb"

# Where per-slice DBs are created during the run (deleted after each slice)
export WORK_DIR="/tmp/scaling_dbs"

# Where to write the results CSV
export RESULTS="/tmp/scaling_validated_results.csv"

# GPU memory split for gpu_buffer_init(CACHE_DATA, CACHE_WORK)
# CACHE_DATA: data cache. CACHE_WORK: working pool for joins/aggregations.
# Total should leave ~10% VRAM free.
# 24 GB GPU:  CACHE_DATA="10 GB"  CACHE_WORK="10 GB"
# 40 GB GPU:  CACHE_DATA="18 GB"  CACHE_WORK="18 GB"
# 80 GB GPU:  CACHE_DATA="36 GB"  CACHE_WORK="36 GB"
export CACHE_DATA="18 GB"
export CACHE_WORK="18 GB"
